theme = "litomore-v3"

font-family = "Maple Mono NF CN ExtraLight"
font-size = 12

window-height = 25
window-width = 140
window-padding-x = 5

cursor-style = bar
cursor-style-blink = false

adjust-cursor-thickness = 100%

shell-integration-features = no-cursor
macos-titlebar-style = hidden
macos-option-as-alt = true

#custom-shader-animation = always

unfocused-split-opacity = 1

background-opacity = 0.8
#background-blur = macos-glass-clear
background-blur-radius = 0

# Shader files are located at https://github.com/LitoMore/ghostty-shaders/tree/litomore
#custom-shader = ~/.config/ghostty/shaders/bettercrt.glsl
custom-shader = ~/.config/ghostty/shaders/water.glsl
#custom-shader = ~/.config/ghostty/shaders/bloom.glsl
